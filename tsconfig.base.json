{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "blog-kit": ["packages/blog-kit/src/index.ts"],
      "blog-kit/editor": ["packages/blog-kit/src/editor.ts"],
      "blog-kit/local": ["packages/blog-kit/src/local.ts"],
      "blog-kit/supabase": ["packages/blog-kit/src/supabase.ts"],
      "blog-kit-core": ["packages/core/src/index.ts"],
      "blog-kit-editor": ["packages/editor/src/index.ts"],
      "blog-kit-local": ["packages/local/src/index.ts"],
      "blog-kit-next": ["packages/adapter-next/src/index.ts"],
      "blog-kit-supabase": ["packages/adapter-supabase/src/index.ts"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmitOnError": true
  }
}
