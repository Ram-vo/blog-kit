{
  "name": "blog-kit-editor",
  "version": "0.6.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "keywords": [
    "blog",
    "editor",
    "mdx",
    "mdxeditor",
    "publishing",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ram-vo/blog-kit"
  },
  "homepage": "https://github.com/Ram-vo/blog-kit#readme",
  "bugs": {
    "url": "https://github.com/Ram-vo/blog-kit/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint not configured yet'",
    "test": "vitest run --environment happy-dom"
  },
  "dependencies": {
    "@mdxeditor/editor": "^3.12.0",
    "blog-kit-core": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
