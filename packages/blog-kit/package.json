{
  "name": "@mrraymondvo/blog-kit",
  "version": "0.5.1",
  "private": false,
  "type": "module",
  "license": "MIT",
  "keywords": [
    "blog",
    "mdx",
    "nextjs",
    "supabase",
    "editorial",
    "publishing",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ram-vo/blog-kit"
  },
  "homepage": "https://github.com/Ram-vo/blog-kit#readme",
  "bugs": {
    "url": "https://github.com/Ram-vo/blog-kit/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "default": "./dist/editor.js"
    },
    "./local": {
      "types": "./dist/local.d.ts",
      "default": "./dist/local.js"
    },
    "./supabase": {
      "types": "./dist/supabase.d.ts",
      "default": "./dist/supabase.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint not configured yet'",
    "test": "echo 'metapackage exports are validated by workspace builds'"
  },
  "dependencies": {
    "blog-kit-core": "workspace:^",
    "blog-kit-editor": "workspace:^",
    "blog-kit-local": "workspace:^",
    "blog-kit-next": "workspace:^",
    "blog-kit-supabase": "workspace:^"
  },
  "publishConfig": {
    "access": "public"
  }
}
